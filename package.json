{
  "name": "babysea",
  "version": "1.3.3",
  "description": "TypeScript SDK for BabySea, the unified API and orchestration layer for generative media across AI models and inference providers.",
  "keywords": [
    "babysea",
    "ai",
    "ai-sdk",
    "sdk",
    "unified-api",
    "api-client",
    "developer-tools",
    "generative-media",
    "image-generation",
    "video-generation",
    "inference",
    "inference-providers",
    "multimodal",
    "text-to-image",
    "image-to-image",
    "text-to-video",
    "image-to-video",
    "video-to-video"
  ],
  "homepage": "https://docs.babysea.ai",
  "bugs": {
    "url": "https://github.com/babysea-ai/babysea/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "BabySea",
    "url": "https://babysea.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-ai/babysea.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks.d.ts",
        "default": "./dist/webhooks.js"
      },
      "require": {
        "types": "./dist/webhooks.d.cts",
        "default": "./dist/webhooks.cjs"
      }
    }
  },
  "files": [
    "dist",
    "badges",
    "README.md",
    "LICENSE",
    "socket.json"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "badges": "node scripts/generate-badges.mjs",
    "prebuild": "pnpm run badges",
    "build": "tsup",
    "clean": "rm -rf .turbo node_modules dist",
    "format": "prettier --check \"**/*.{mjs,ts,md,json}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format",
    "prepublishOnly": "pnpm run check && pnpm run build"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/prettier-config": "workspace:*",
    "@kit/tsconfig": "workspace:*",
    "badge-maker": "^5.0.2",
    "tsup": "catalog:",
    "typescript": "^5.9.3"
  },
  "prettier": "@kit/prettier-config"
}
