{
  "name": "babysea",
  "version": "1.4.3",
  "description": "Open source TypeScript SDK for the BabySea execution control plane for generative media.",
  "keywords": [
    "babysea",
    "open-source",
    "sdk",
    "ai-infrastructure",
    "control-plane",
    "execution-layer",
    "developer-tools",
    "generative-ai",
    "inference-providers",
    "enterprise-infrastructure",
    "multi-region"
  ],
  "homepage": "https://docs.babysea.ai",
  "bugs": {
    "url": "https://github.com/babysea-ai/babysea/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "BabySea",
    "url": "https://babysea.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babysea-ai/babysea.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks.d.ts",
        "default": "./dist/webhooks.js"
      },
      "require": {
        "types": "./dist/webhooks.d.cts",
        "default": "./dist/webhooks.cjs"
      }
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "socket.json"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "version:generate": "node scripts/generate-version.mjs",
    "prebuild": "node scripts/generate-version.mjs",
    "build": "tsup",
    "clean": "rm -rf .turbo node_modules dist",
    "format": "prettier --check \"**/*.{mjs,ts,md,json}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run format",
    "prepublishOnly": "npm run check && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "prettier": {
    "arrowParens": "always",
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": false
  }
}
